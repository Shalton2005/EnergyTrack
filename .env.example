# Flask Configuration
SECRET_KEY=replace-with-a-long-random-secret
FLASK_ENV=production
FLASK_DEBUG=False

# Email Configuration (OPTIONAL - app works without email)
# Leave MAIL_USERNAME empty to disable email features
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@energytrack.app

# Database
DATABASE_URI=sqlite:///database.db

# Admin Email
ADMIN_EMAIL=admin@energytrack.local
ADMIN_PASSWORD=replace-with-strong-password
